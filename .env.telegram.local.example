# QuantGod P3-2 Telegram push-only local config.
# Copy this file to .env.telegram.local and keep the local file uncommitted.
# Token comes from @BotFather. Chat ID is discovered by tools/run_telegram_notifier.py link.
QG_TELEGRAM_PUSH_ALLOWED=0
QG_TELEGRAM_COMMANDS_ALLOWED=0
QG_TELEGRAM_BOT_TOKEN=
QG_TELEGRAM_CHAT_ID=
QG_TELEGRAM_API_BASE_URL=https://api.telegram.org
QG_TELEGRAM_TIMEOUT_SECONDS=15

# Optional Polymarket copy-trader Telegram intake. Bot API can only read
# channel posts after the bot is added to that channel. Telethon uses a
# read-only user session for channels already visible in your Telegram account.
QG_POLYMARKET_TELEGRAM_CHANNEL_NAME=预测市场内幕钱包监控
QG_POLYMARKET_TELEGRAM_ENTITY=预测市场内幕钱包监控
QG_TELEGRAM_API_ID=
QG_TELEGRAM_API_HASH=
QG_TELETHON_SESSION=runtime/telegram/polymarket_channel

# Optional MT5 AI monitor defaults. The monitor remains read-only and
# advisory-only; --send is required before it can push to Telegram.
QG_MT5_AI_MONITOR_SYMBOLS=USDJPYc
QG_MT5_AI_MONITOR_TIMEFRAMES=M15,H1,H4,D1
QG_MT5_AI_MONITOR_MIN_INTERVAL_SECONDS=900
QG_MT5_AI_MONITOR_MIN_CONFIDENCE_PCT=70
