# QuantGod P3-2 Telegram push-only local config.
# Copy this file to .env.telegram.local and keep the local file uncommitted.
# Token comes from @BotFather. Chat ID is discovered by tools/run_telegram_notifier.py link.
QG_TELEGRAM_PUSH_ALLOWED=0
QG_TELEGRAM_COMMANDS_ALLOWED=0
QG_TELEGRAM_BOT_TOKEN=
QG_TELEGRAM_CHAT_ID=
QG_TELEGRAM_API_BASE_URL=https://api.telegram.org
QG_TELEGRAM_TIMEOUT_SECONDS=15
