# QuantGod P3-14 USDJPY-only 策略实验室本机配置。
# 需要时复制为 .env.usdjpy.local；不要提交 .env.usdjpy.local。

QG_FOCUS_SYMBOL=USDJPYc
QG_ALLOWED_SYMBOLS=USDJPYc
QG_DISABLE_NON_FOCUS_SYMBOLS=1
QG_USDJPY_MIN_SAMPLES=5

# USDJPY 政策仓位上限；这不是每次固定手数。
# 实际建议仓位仍会按证据评分和入场模式缩放。
QG_AUTO_MAX_LOT=2.0
QG_AUTO_MIN_LOT=0.01
QG_AUTO_LOT_STEP=0.01
QG_AUTO_RISK_PER_TRADE_PCT=0.5
QG_AUTO_OPPORTUNITY_LOT_MULTIPLIER=0.35
QG_AUTO_STANDARD_LOT_MULTIPLIER=1.0
QG_AUTO_ACCOUNT_EQUITY=1000.0

# 本实验室只做干跑和建议。EA 实盘执行必须单独实现、单独 review。
QG_USDJPY_DRY_RUN_ONLY=1
QG_TELEGRAM_COMMANDS_ALLOWED=0
