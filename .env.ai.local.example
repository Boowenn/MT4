# QuantGod AI Provider Router local env example.
# Copy to .env.ai.local and keep that file uncommitted.
# Do not paste secrets into this example file.

# Router defaults. Keep disabled until a local API key exists.
QG_AI_ENABLED=0
QG_AI_PROVIDER=deepseek
QG_AI_MODEL=deepseek-v4-flash
QG_AI_BASE_URL=https://api.deepseek.com
QG_AI_TIMEOUT_SECONDS=45
QG_AI_MAX_TOKENS=1800
QG_AI_TEMPERATURE=0.25
QG_AI_REQUIRE_JSON=1

# Secret. Leave empty in the example.
QG_AI_API_KEY=

# Local guardrails.
QG_AI_DAILY_CALL_LIMIT=50
QG_AI_DAILY_BUDGET_USD=2.00
QG_AI_LOG_PROMPTS=0
QG_AI_LOG_RESPONSES=0

# Hard safety defaults. These must remain disabled.
QG_ORDER_SEND_ALLOWED=0
QG_CLOSE_ALLOWED=0
QG_CANCEL_ALLOWED=0
QG_CREDENTIAL_STORAGE_ALLOWED=0
QG_LIVE_PRESET_MUTATION_ALLOWED=0
QG_CAN_OVERRIDE_KILL_SWITCH=0
QG_TELEGRAM_COMMANDS_ALLOWED=0
QG_TELEGRAM_WEBHOOK_RECEIVER_ALLOWED=0
QG_WEBHOOK_RECEIVER_ALLOWED=0
QG_EMAIL_DELIVERY_ALLOWED=0
