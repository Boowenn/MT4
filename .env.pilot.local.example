# QuantGod P3-10 Pilot Safety Lock example.
# Copy to .env.pilot.local and edit locally only. Do not commit .env.pilot.local.

# Default is blocked. Setting this to 1 still does NOT send orders; it only lets the preflight report become armable if every evidence check passes.
QG_PILOT_EXECUTION_ALLOWED=0

# Must be typed locally by the operator when arming manual minimal-lot pilot review.
# Required exact phrase: 我确认仅允许最小仓位试点，禁止自动扩大风险
QG_PILOT_CONFIRMATION_PHRASE=

# Hard caps. The tool rejects values above these defaults.
QG_PILOT_MAX_LOT=0.01
QG_PILOT_MAX_DAILY_TRADES=3
QG_PILOT_MAX_DAILY_LOSS_R=1.0

# Explicit allowlists.
QG_PILOT_ALLOWED_SYMBOLS=USDJPYc
QG_PILOT_ALLOWED_STRATEGIES=RSI_Reversal

# Telegram remains push-only.
QG_TELEGRAM_COMMANDS_ALLOWED=0
